generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id           String   @id @default(cuid())
  name         String
  organization String?
  category     String   @default("Others")
  otherCategory String?
  phoneNumber  String
  designation  String?
  address      String?
  comments     String?
  callHistory  CallHistory[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([organization])
  @@index([designation])
  @@index([createdAt])
}

model CallHistory {
  id             String   @id @default(cuid())
  contactId       String?
  contactName     String
  organization    String?
  phoneNumber     String
  calledAt        DateTime @default(now())

  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([calledAt])
  @@index([contactId])
  @@index([organization])
}
